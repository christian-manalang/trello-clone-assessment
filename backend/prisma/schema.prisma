generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Ticket {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String?
  status      String   @default("TODO")
  priority    String   @default("LOW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}